{
  "name": "letant",
  "version": "0.0.2",
  "description": "AST based language-agnostic structural code comprehension",
  "keywords": [],
  "author": "Juun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juunie-roh/letant.git"
  },
  "homepage": "https://github.com/juunie-roh/letant#readme",
  "bugs": {
    "url": "https://github.com/juunie-roh/letant/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "bin": "dist/bin/letant.js",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/config/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/config/index.js"
      }
    },
    "./dot": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/dot/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/dot/index.js"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/utils/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/utils/index.js"
      }
    },
    "./query": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/utils/query/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/utils/query/index.js"
      }
    }
  },
  "scripts": {
    "attw": "attw --pack --ignore-rules 'no-resolution'",
    "attw:quiet": "attw --pack --quiet --ignore-rules 'no-resolution'",
    "attw:all": "pnpm attw:quiet && pnpm -r attw:quiet",
    "build": "tsup",
    "build:all": "pnpm build && pnpm -r build",
    "check-types": "tsc -p ./tsconfig.json --noEmit",
    "check-types:all": "tsc -p ./tsconfig.json --noEmit && pnpm -r check-types",
    "dev": "tsup --watch",
    "dev:config": "LOG_LEVEL=debug node dist/bin/letant.js --config src/__mocks__/letant.config.json",
    "lint": "eslint . --cache",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest watch --coverage",
    "js": "pnpm --filter @juun-roh/letant-js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "tree-sitter": "^0.25.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.1",
    "@commitlint/format": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@juun-roh/letant-js": "workspace:*",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "4.1.2",
    "esbuild": "^0.27.7",
    "eslint": "^10.2.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4",
      "lodash": ">=4.17.23",
      "minimatch": ">=10.2.1"
    }
  }
}
