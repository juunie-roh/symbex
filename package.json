{
  "name": "@juun-roh/spine",
  "version": "0.0.0",
  "description": "An AST-based code indexer",
  "keywords": [],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "bin": "dist/bin/spine.js",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc -p ./tsconfig.json --noEmit",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "prepare": "husky",
    "run:dev": "node dist/bin/spine.js -p __mocks__/spine.config.json",
    "test": "echo \"Error: no test specified\" && exit 1",
    "ts": "pnpm --filter @juun-roh/spine-typescript",
    "tsx": "pnpm --filter @juun-roh/spine-tsx"
  },
  "author": "Juun",
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "tree-sitter": "^0.25.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@commitlint/cz-commitlint": "^20.4.1",
    "@commitlint/format": "^20.4.0",
    "@commitlint/types": "^20.4.0",
    "@eslint/js": "^10.0.1",
    "@juun-roh/spine-tsx": "workspace:*",
    "@juun-roh/spine-typescript": "workspace:*",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-plugin-jsdoc": "^62.7.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4",
      "lodash": ">=4.17.23",
      "minimatch": ">=10.2.1"
    }
  }
}
