{
  "name": "@juun-roh/letant-js",
  "version": "0.0.2",
  "description": "JavaScript plugin for letant",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "attw": "attw --pack --ignore-rules 'no-resolution'",
    "attw:quiet": "attw --pack --quiet --ignore-rules 'no-resolution'",
    "build": "tsup",
    "check-types": "tsc -p ./tsconfig.json --noEmit",
    "dev": "tsup --watch",
    "dev:query": "pnpm letant query --grammar tree-sitter-javascript"
  },
  "keywords": [],
  "author": "Juun",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "peerDependencies": {
    "letant": "^0.0.2",
    "tree-sitter-javascript": "^0.25.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "letant": "workspace:*",
    "tree-sitter-javascript": "^0.25.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
