{
  "name": "@juun-roh/letant-js",
  "version": "0.0.0",
  "description": "JavaScript plugin for letant",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc -p ./tsconfig.json --noEmit",
    "dev": "tsup --watch",
    "dev:query": "pnpm letant query --grammar tree-sitter-javascript"
  },
  "keywords": [],
  "author": "Juun",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "peerDependencies": {
    "letant": "^0.0.0",
    "tree-sitter-javascript": "^0.25.0"
  },
  "devDependencies": {
    "letant": "workspace:*",
    "tree-sitter-javascript": "^0.25.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
