{
  "name": "symbex",
  "version": "0.0.2",
  "description": "A language-agnostic scope graph provider",
  "keywords": [],
  "author": "Juun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juunie-roh/symbex.git"
  },
  "homepage": "https://github.com/juunie-roh/symbex#readme",
  "bugs": {
    "url": "https://github.com/juunie-roh/symbex/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "bin": "dist/bin/symbex.js",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./dot": {
      "types": "./dist/dot/index.d.ts",
      "default": "./dist/dot/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./query": {
      "types": "./dist/query/index.d.ts",
      "default": "./dist/query/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:all": "pnpm build && pnpm -r build",
    "check-types": "tsc -p ./tsconfig.json --noEmit",
    "check-types:all": "tsc -p ./tsconfig.json --noEmit && pnpm -r check-types",
    "dev": "tsup --watch",
    "dev:config": "node dist/bin/symbex.js --config __mocks__/symbex.config.json",
    "lint": "eslint . --cache",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest watch --coverage",
    "js": "pnpm --filter @symbex/javascript"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "tree-sitter": "^0.25.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.0",
    "@commitlint/format": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@symbex/javascript": "workspace:*",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4",
      "lodash": ">=4.17.23",
      "minimatch": ">=10.2.1"
    }
  }
}
